generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String         @default("")
  passwordHash        String
  role                Role           @default(STAFF)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  refreshTokens       RefreshToken[]
  patients            Patient[]
  appointments        Appointment[]  @relation("AppointmentUser")
  createdAppointments Appointment[]  @relation("AppointmentCreatedBy")
  clinicalNotes       ClinicalNote[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // SHA-256(rawRefreshJWT) as hex string
  familyId  String // UUID shared by all rotations in a session
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model Patient {
  id           String    @id @default(cuid())
  fullName     String
  cpf          String    @unique
  phone        String
  birthDate    DateTime  @db.Date
  email        String?
  observations String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  createdBy    User          @relation(fields: [createdById], references: [id])
  appointments Appointment[]

  @@index([fullName])
  @@index([email])
  // Trigram GIN indexes back fuzzy ILIKE search on Patient.fullName / Patient.email.
  // Created by migration 20260520211658_add_patient via raw SQL; modeled here so
  // `prisma migrate dev` no longer emits spurious DROP INDEX drift.
  @@index([fullName(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_patient_fullname_trgm")
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_patient_email_trgm")
}

enum AppointmentType {
  CONSULTA
  RETORNO
  AVALIACAO
  PROCEDIMENTO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  AGUARDANDO
  EM_ATENDIMENTO
  REALIZADO
  CANCELADO
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  userId          String
  startsAt        DateTime
  endsAt          DateTime
  durationMinutes Int               @default(30)
  type            AppointmentType
  insurance       String
  value           Decimal?          @db.Decimal(10, 2)
  observations    String?
  status          AppointmentStatus @default(AGENDADO)
  createdById     String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  cancelledAt     DateTime?
  cancelReason    String?

  patient       Patient            @relation(fields: [patientId], references: [id])
  user          User               @relation("AppointmentUser", fields: [userId], references: [id])
  createdBy     User               @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  events        AppointmentEvent[]
  clinicalNotes ClinicalNote[]

  @@index([userId, startsAt])
  @@index([patientId, startsAt])
  @@index([status, startsAt])
  @@index([startsAt])
}

model AppointmentEvent {
  id            String   @id @default(cuid())
  appointmentId String
  action        String
  fromStatus    String?
  toStatus      String?
  byUserId      String
  payload       Json?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model ClinicalNote {
  id            String   @id @default(cuid())
  appointmentId String
  authorId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  author      User                   @relation(fields: [authorId], references: [id])
  revisions   ClinicalNoteRevision[]

  @@index([appointmentId])
  @@index([authorId])
}

model ClinicalNoteRevision {
  id        String   @id @default(cuid())
  noteId    String
  content   Json
  createdAt DateTime @default(now())

  note ClinicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
}
